{
  "name": "ollama-spaceship",
  "version": "1.0.0",
  "description": "Complete reference for every module in `src/apis/`.   The entry points are **`client.ts`** (low-level singleton) and **`ClientLibrary.ts`** (high-level class wrapper).",
  "main": "postcss.config.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p ./tsconfig.json",
    "preview": "vite preview",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:fail": "node --experimental-vm-modules node_modules/.bin/jest --reporters=./jest-fail-reporter.cjs",
    "test:client": "npx tsx src/apis/client.test.ts",
    "docs": "npx typedoc --entryPoints src --entryPointStrategy expand --out docs/api --tsconfig tsconfig.test.json --skipErrorChecking"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santenova/ollama-spaceship.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/santenova/ollama-spaceship/issues"
  },
  "homepage": "https://github.com/santenova/ollama-spaceship#readme",
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^26.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "autoprefixer": "^10.5.2",
    "expect": "^30.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  }
}
